---
/*
  Site header. On pages with a full-screen hero (overlay=true) it sits
  transparently over the banner with a white logo and links; once the user
  scrolls past the hero, a tiny script sets [data-solid] on the header and the
  data-solid:/group-data-solid: variants below restyle it to solid white. All
  visual state lives in this markup — the script only flips the attribute.
  On other pages it is solid from the start. Navigation works without JS.
*/
interface Props {
  overlay?: boolean;
}
const { overlay = false } = Astro.props;

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Behandelingen', href: '/behandelingen' },
  { label: 'Praktijk', href: '/praktijk' },
  { label: 'Contact', href: '/contact' },
];

// Trailing-slash-insensitive path comparison; '/' normalizes to itself so the
// home link also gets its active state.
const normalize = (path: string) => path.replace(/\/+$/, '') || '/';
const current = normalize(Astro.url.pathname);

---

<header
  id="site-header"
  data-overlay={overlay ? '' : undefined}
  class:list={[
    'group fixed inset-x-0 top-0 z-40 transition-colors duration-300',
    overlay
      ? 'bg-transparent text-white data-solid:bg-white/95 data-solid:text-brand-green-dark data-solid:shadow-sm data-solid:backdrop-blur'
      : 'border-b border-brand-pink-soft bg-white/95 text-brand-green-dark backdrop-blur',
  ]}
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center" aria-label="Dermatologie Nazareth — home">
      <img
        src="/assets/logo.png"
        alt="Dermatologie Nazareth"
        class:list={[
          'h-12 w-auto transition-[filter] duration-300',
          overlay && 'logo-on-dark group-data-solid:filter-none',
        ]}
        width="904"
        height="434"
      />
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => {
          const active = current === normalize(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'text-xs uppercase tracking-widest transition-opacity hover:opacity-100',
                  active ? 'opacity-100' : 'opacity-75',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="/afspraak"
        class:list={[
          'hidden rounded-md px-5 py-2 text-xs uppercase tracking-widest transition-colors sm:inline-block',
          overlay
            ? 'border border-white/60 hover:bg-white hover:text-brand-green group-data-solid:border-transparent group-data-solid:bg-brand-green group-data-solid:text-white group-data-solid:hover:bg-brand-green-dark group-data-solid:hover:text-white'
            : 'bg-brand-green text-white hover:bg-brand-green-dark',
        ]}
      >
        Afspraak maken
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 md:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Menu openen</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile navigation panel -->
  <div id="mobile-menu" class="hidden border-t border-brand-pink-soft bg-white text-brand-green-dark md:hidden">
    <ul class="mx-auto max-w-6xl space-y-1 px-4 py-3 sm:px-6">
      {
        nav.map((item) => {
          const active = current === normalize(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={active ? 'page' : undefined}
                class:list={['block rounded-md px-2 py-2 hover:bg-brand-cream', active && 'bg-brand-cream']}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
      <li>
        <a href="/afspraak" class="mt-2 block rounded-md bg-brand-green px-5 py-2 text-center text-white">
          Afspraak maken
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu disclosure.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  // On hero-overlay pages, flag the header as solid once scrolled past the
  // top; the data-solid: variants in the markup do the actual restyling.
  const header = document.getElementById('site-header');
  if (header?.hasAttribute('data-overlay')) {
    const onScroll = () => header.toggleAttribute('data-solid', window.scrollY > 60);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
