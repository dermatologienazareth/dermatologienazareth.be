---
/*
  Site header. On pages with a full-screen hero (overlay=true) it sits
  transparently over the banner with a white logo and links, then turns solid
  white once the user scrolls past the hero (toggled by a small scroll script).
  On other pages it is solid from the start. Navigation works without JS.
*/
import { getEntry } from 'astro:content';

interface Props {
  overlay?: boolean;
}
const { overlay = false } = Astro.props;

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Behandelingen', href: '/behandelingen' },
  { label: 'Praktijk', href: '/praktijk' },
  { label: 'Contact', href: '/contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';

const contact = await getEntry('settings', 'contact');
const bookingUrl = contact?.data.bookingUrl ?? '#';
---

<header
  id="site-header"
  data-overlay={overlay ? '' : undefined}
  class:list={[
    'fixed inset-x-0 top-0 z-40 transition-colors duration-300',
    overlay ? 'bg-transparent text-white' : 'border-b border-brand-pink-soft bg-white/95 text-brand-green-dark backdrop-blur',
  ]}
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center" aria-label="Dermatologie Nazareth — home">
      <img
        src="/assets/logo.svg"
        alt="Dermatologie Nazareth"
        class:list={['h-12 w-auto transition-[filter] duration-300', overlay && 'logo-on-dark']}
        width="200"
        height="200"
      />
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => {
          const active = current === item.href.replace(/\/$/, '');
          return (
            <li>
              <a
                href={item.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'text-xs uppercase tracking-widest transition-opacity hover:opacity-100',
                  active ? 'opacity-100' : 'opacity-75',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        class:list={[
          'hidden rounded-md px-5 py-2 text-xs uppercase tracking-widest transition-colors sm:inline-block',
          overlay
            ? 'border border-white/60 hover:bg-white hover:text-brand-green'
            : 'bg-brand-green text-white hover:bg-brand-green-dark',
        ]}
      >
        Afspraak maken
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 md:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Menu openen</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile navigation panel -->
  <div id="mobile-menu" class="hidden border-t border-brand-pink-soft bg-white text-brand-green-dark md:hidden">
    <ul class="mx-auto max-w-6xl space-y-1 px-4 py-3 sm:px-6">
      {
        nav.map((item) => (
          <li>
            <a href={item.href} class="block rounded-md px-2 py-2 hover:bg-brand-cream">
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener"
          class="mt-2 block rounded-md bg-brand-green px-5 py-2 text-center text-white"
        >
          Afspraak maken
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu disclosure.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  // On hero-overlay pages, swap the header to solid once scrolled past the top.
  const header = document.getElementById('site-header');
  if (header?.hasAttribute('data-overlay')) {
    const logo = header.querySelector('img');
    const cta = header.querySelector('a[rel="noopener"]');
    const onScroll = () => {
      const solid = window.scrollY > 60;
      header.classList.toggle('bg-transparent', !solid);
      header.classList.toggle('text-white', !solid);
      header.classList.toggle('bg-white/95', solid);
      header.classList.toggle('backdrop-blur', solid);
      header.classList.toggle('text-brand-green-dark', solid);
      header.classList.toggle('shadow-sm', solid);
      logo?.classList.toggle('logo-on-dark', !solid);
      // CTA style flips between outlined-on-dark and filled-green.
      cta?.classList.toggle('border', !solid);
      cta?.classList.toggle('border-white/60', !solid);
      cta?.classList.toggle('bg-brand-green', solid);
      cta?.classList.toggle('text-white', solid);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
