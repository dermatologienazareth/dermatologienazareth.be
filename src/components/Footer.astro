---
/*
  Dark footer band with practice contact details and opening hours, all sourced
  from the settings singleton so the client manages them through the CMS.
*/
import { getEntry } from 'astro:content';
import { isEmail, telHref } from '../lib/text';

const contact = await getEntry('settings', 'contact');
const c = contact?.data;
// Blank while the practice mailbox is not yet active — the row is then hidden.
const email = c?.email.trim() ?? '';
const year = new Date().getFullYear();
---

<footer class="bg-brand-green-dark text-white">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 md:grid-cols-3">
    <div>
      <img src="/assets/logo-white.png" alt="Dermatologie Nazareth" class="h-28 w-auto" width="631" height="437" />
    </div>

    {
      c && (
        <div>
          <h2 class="mb-4 text-sm uppercase tracking-widest text-brand-pink-soft/90">Contact</h2>
          <address class="space-y-1 text-sm not-italic text-white/75">
            <p>{c.addressLine}</p>
            <p>{c.postalCode} {c.city}</p>
            <p>
              <a href={telHref(c.phone)} class="hover:text-white">{c.phone}</a>
              {c.phoneNote && <span class="text-white/50"> ({c.phoneNote})</span>}
            </p>
            {email && (
              <p>
                {isEmail(email) ? (
                  <a href={`mailto:${email}`} class="hover:text-white">{email}</a>
                ) : (
                  email
                )}
              </p>
            )}
          </address>
        </div>
      )
    }

    {
      c && (
        <div>
          <h2 class="mb-4 text-sm uppercase tracking-widest text-brand-pink-soft/90">Openingsuren</h2>
          <ul class="space-y-1 text-sm text-white/75">
            {c.openingHours.map((row) => (
              <li class="flex justify-between gap-4">
                <span>{row.day}</span>
                <span>{row.hours}</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>

  <div class="border-t border-white/10">
    <p class="mx-auto max-w-6xl px-4 py-5 text-center text-xs text-white/50 sm:px-6">
      © {year} {c?.practiceName ?? 'Dermatologie Nazareth'}. Alle rechten voorbehouden.
    </p>
  </div>
</footer>
