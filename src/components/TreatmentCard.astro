---
/*
  Card for a single treatment. Renders the CMS-provided image when present,
  otherwise a calm brand-tinted placeholder so the grid stays consistent even
  before images are uploaded.
*/
interface Props {
  title: string;
  summary: string;
  image?: string;
}

const { title, summary, image } = Astro.props;
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-brand-pink-soft bg-white transition-[border-color,box-shadow] duration-300 hover:border-brand-pink/70 hover:shadow-lg hover:shadow-brand-pink/20">
  {
    image ? (
      <img src={image} alt={title} class="h-44 w-full object-cover" loading="lazy" width="600" height="352" />
    ) : (
      <div
        class="flex h-44 w-full items-center justify-center bg-gradient-to-br from-brand-pink-soft to-brand-pink/40"
        aria-hidden="true"
      >
        <svg class="h-10 w-10 text-brand-green/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-lg text-brand-green">{title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-brand-green-dark/75">{summary}</p>
  </div>
</article>
