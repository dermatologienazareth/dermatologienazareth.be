---
// Stub page — full contact page (map, route, hours) follows in phase 2.
// Copy comes from the `pages` collection (CMS: Pagina's → Pagina Contact);
// the contact details themselves come from the settings singleton, the same
// source the footer uses.
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isEmail, paragraphs, telHref } from '../lib/text';

const page = await getEntry('pages', 'contact');
if (!page) {
  throw new Error('Ontbrekende inhoud: src/content/pages/contact.json');
}

const contact = await getEntry('settings', 'contact');
const c = contact?.data;
---

<BaseLayout title={page.data.seo.title} description={page.data.seo.description}>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <h1 class="text-3xl text-brand-green sm:text-4xl">{page.data.title}</h1>
    <div class="mx-auto mt-4 h-0.5 w-10 rounded-full bg-brand-pink" aria-hidden="true"></div>
    {
      c && (
        <div class="mt-6 space-y-1 text-brand-green-dark/80">
          <p>{c.addressLine}</p>
          <p>{c.postalCode} {c.city}</p>
          <p>
            <a href={telHref(c.phone)} class="hover:text-brand-green">{c.phone}</a>
            {c.phoneNote && <span class="text-brand-green-dark/60"> ({c.phoneNote})</span>}
          </p>
          <p>
            {isEmail(c.email) ? (
              <a href={`mailto:${c.email}`} class="hover:text-brand-green">{c.email}</a>
            ) : (
              c.email
            )}
          </p>
        </div>
      )
    }
    <div class="mt-6 space-y-4">
      {paragraphs(page.data.intro).map((p) => <p class="text-sm text-brand-green-dark/60">{p}</p>)}
    </div>
  </section>
</BaseLayout>
