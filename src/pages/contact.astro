---
// Stub page — full contact page (map, route, hours) follows in phase 2.
// Core contact details already render site-wide via the footer.
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const contact = await getEntry('settings', 'contact');
const c = contact?.data;
---

<BaseLayout
  title="Contact — Dermatologie Nazareth"
  description="Contactgegevens, adres en openingsuren van Dermatologie Nazareth."
>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <h1 class="text-3xl text-brand-green sm:text-4xl">Contact</h1>
    {
      c && (
        <div class="mt-6 space-y-1 text-brand-green-dark/80">
          <p>{c.addressLine}</p>
          <p>{c.postalCode} {c.city}</p>
          <p>
            <a href={`tel:${c.phone.replace(/\s/g, '')}`} class="hover:text-brand-green">{c.phone}</a>
          </p>
          <p>
            <a href={`mailto:${c.email}`} class="hover:text-brand-green">{c.email}</a>
          </p>
        </div>
      )
    }
    <p class="mt-6 text-sm text-brand-green-dark/60">
      Deze pagina wordt binnenkort verder uitgewerkt met route en kaart.
    </p>
  </section>
</BaseLayout>
