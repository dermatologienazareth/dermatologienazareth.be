---
/*
  Home page, laid out in the style of the reference practice (HTML5 UP
  "Stellar"): a full-viewport banner hero, alternating spotlight bands, a
  treatments grid, a practical-info section and a closing contact call to
  action. All copy comes from the `homePage` collection (CMS: Pagina's →
  Homepagina); this component only provides the structure.
*/
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Spotlight from '../components/Spotlight.astro';
import TreatmentCard from '../components/TreatmentCard.astro';
import { paragraphs, telHref } from '../lib/text';

const home = await getEntry('homePage', 'home');
if (!home) {
  throw new Error('Ontbrekende inhoud: src/content/pages/home.json');
}
const { hero, intro, doctorSpotlight, practiceSpotlight, treatmentsSection, practicalSection, contactCta } =
  home.data;

// The homepage grid shows only treatments marked "Uitgelicht" in the CMS;
// the full list lives on /behandelingen.
const treatments = (await getCollection('treatments'))
  .filter((t) => t.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// The featured team member is picked in the CMS via a relation field; name,
// photo and bio all come from that team entry. If the entry was deleted the
// section is skipped rather than failing the client's deploy.
const doctor = await getEntry('team', doctorSpotlight.member);
if (!doctor) {
  console.warn(`[home] teamlid "${doctorSpotlight.member}" niet gevonden — sectie "Uw huidarts" wordt overgeslagen.`);
}
const DoctorBio = doctor ? (await render(doctor)).Content : null;

const contact = await getEntry('settings', 'contact');
const c = contact?.data;

// "{telefoon}" in the CTA text marks where the clickable phone number goes.
const ctaTextParts = contactCta.text.split('{telefoon}');
---

<BaseLayout heroOverlay title={home.data.seo.title} description={home.data.seo.description}>
  <!-- Banner hero -->
  <section
    class="banner text-white"
    style="background-image: linear-gradient(160deg, #6b7266 0%, #4b5147 100%);"
  >
    <!-- Subtle vignette so the white type stays legible. -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(120% 120% at 50% 30%, transparent 40%, rgba(0,0,0,0.35) 100%);"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 flex flex-col items-center px-6">
      <img
        src="/assets/logo.png"
        alt="Dermatologie Nazareth"
        class="logo-on-dark mb-8 w-40 sm:w-48"
        width="904"
        height="434"
      />
      <h1 class="banner-title text-2xl sm:text-3xl">{hero.title}</h1>
      <p class="mt-6 max-w-xl text-base text-white/85 sm:text-lg">{hero.tagline}</p>
      {
        c && (
          <a
            href="/afspraak"
            class="mt-8 rounded-md bg-white px-7 py-3 text-xs uppercase tracking-widest text-brand-green transition-colors hover:bg-brand-pink-soft"
          >
            {hero.ctaLabel}
          </a>
        )
      }
    </div>

    <a href="#welkom" class="scroll-cue" aria-label="Naar de inhoud scrollen"></a>
  </section>

  <!-- Intro -->
  <section id="welkom" class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <p class="eyebrow mb-3 text-brand-pink">{intro.eyebrow}</p>
    <h2 class="section-title text-2xl text-brand-green sm:text-3xl">{intro.title}</h2>
    <div class="mt-5 space-y-4">
      {paragraphs(intro.text).map((p) => <p class="text-lg leading-relaxed text-brand-green-dark/80">{p}</p>)}
    </div>
  </section>

  <!-- Spotlight: the featured team member -->
  {
    doctor && DoctorBio && (
      <Spotlight
        eyebrow={doctorSpotlight.eyebrow}
        title={doctor.data.name}
        image={doctor.data.photo}
        imageAlt={doctor.data.name}
        tone="pink"
        ctaLabel={doctorSpotlight.ctaLabel}
        ctaHref="/praktijk"
      >
        <DoctorBio />
      </Spotlight>
    )
  }

  <!-- Spotlight: the practice (reversed) -->
  <Spotlight
    eyebrow={practiceSpotlight.eyebrow}
    title={practiceSpotlight.title}
    image={practiceSpotlight.image}
    imageAlt={practiceSpotlight.title}
    reverse
    ctaLabel={practiceSpotlight.ctaLabel}
    ctaHref="/behandelingen"
  >
    {paragraphs(practiceSpotlight.text).map((p) => <p>{p}</p>)}
  </Spotlight>

  <!-- Treatments grid (featured entries from the content collection) -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-12 text-center">
        <p class="eyebrow mb-3 text-brand-pink">{treatmentsSection.eyebrow}</p>
        <h2 class="section-title text-2xl text-brand-green sm:text-3xl">{treatmentsSection.title}</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          treatments.map((t) => (
            <TreatmentCard title={t.data.title} summary={t.data.summary} image={t.data.image} />
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <a
          href="/behandelingen"
          class="inline-block rounded-md border border-brand-green/30 px-7 py-3 text-xs uppercase tracking-widest text-brand-green transition-colors hover:bg-brand-green hover:text-white"
        >
          {treatmentsSection.ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- Practical info: the dusty-rose band. The warm brand colour carries the
       patient-care content, while green stays the clinical voice (hero,
       buttons, footer). Text is full green-dark for AA contrast on rose. -->
  <section class="bg-brand-pink/60 text-brand-green-dark">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="mb-12 text-center">
        <p class="eyebrow mb-3 text-brand-green">{practicalSection.eyebrow}</p>
        <h2 class="section-title text-2xl sm:text-3xl">{practicalSection.title}</h2>
      </div>
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          practicalSection.items.map((item) => (
            <div class="text-center">
              <h3 class="text-base uppercase tracking-wider">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing contact CTA -->
  {
    c && (
      <section class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6">
        <p class="eyebrow mb-3 text-brand-pink">{contactCta.eyebrow}</p>
        <h2 class="section-title text-2xl text-brand-green sm:text-3xl">{contactCta.title}</h2>
        <p class="mt-5 text-brand-green-dark/80">
          {ctaTextParts.map((part, i) => (
            <Fragment>
              {i > 0 && (
                <a href={telHref(c.phone)} class="text-brand-green underline-offset-4 hover:underline">
                  {c.phone}
                </a>
              )}
              {part}
            </Fragment>
          ))}
        </p>
        <a
          href="/afspraak"
          class="mt-8 inline-block rounded-md bg-brand-green px-8 py-3 text-xs uppercase tracking-widest text-white transition-colors hover:bg-brand-green-dark"
        >
          {contactCta.ctaLabel}
        </a>
      </section>
    )
  }
</BaseLayout>
