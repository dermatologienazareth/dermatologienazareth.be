---
/*
  Booking page — every "Afspraak maken" button on the site leads here. The
  copy comes from the `pages` collection (CMS: Pagina's → Pagina Afspraak);
  the action block below it derives from Instellingen → Contactgegevens:
  while `bookingUrl` is empty the phone number is the primary action, once it
  is filled the online agenda becomes primary with the phone as fallback.
*/
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { paragraphs, telHref } from '../lib/text';

const page = await getEntry('pages', 'afspraak');
if (!page) {
  throw new Error('Ontbrekende inhoud: src/content/pages/afspraak.json');
}

const contact = await getEntry('settings', 'contact');
const c = contact?.data;
---

<BaseLayout title={page.data.seo.title} description={page.data.seo.description}>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <h1 class="text-3xl text-brand-green sm:text-4xl">{page.data.title}</h1>
    <div class="mx-auto mt-4 h-0.5 w-10 rounded-full bg-brand-pink" aria-hidden="true"></div>
    <div class="mt-4 space-y-4">
      {paragraphs(page.data.intro).map((p) => <p class="text-brand-green-dark/75">{p}</p>)}
    </div>

    {
      c && (
        <div class="mt-10 flex flex-col items-center gap-3">
          {c.bookingUrl ? (
            <>
              <a
                href={c.bookingUrl}
                target="_blank"
                rel="noopener"
                class="inline-block rounded-md bg-brand-green px-8 py-3 text-xs uppercase tracking-widest text-white transition-colors hover:bg-brand-green-dark"
              >
                Online afspraak maken
              </a>
              <p class="text-sm text-brand-green-dark/75">
                of bel{' '}
                <a href={telHref(c.phone)} class="text-brand-green underline-offset-4 hover:underline">
                  {c.phone}
                </a>
                {c.phoneNote && <span class="text-brand-green-dark/60"> ({c.phoneNote})</span>}
              </p>
            </>
          ) : (
            <>
              <a
                href={telHref(c.phone)}
                class="inline-block rounded-md bg-brand-green px-8 py-3 text-xs uppercase tracking-widest text-white transition-colors hover:bg-brand-green-dark"
              >
                Bel {c.phone}
              </a>
              {c.phoneNote && <p class="text-sm text-brand-green-dark/60">({c.phoneNote})</p>}
            </>
          )}
        </div>
      )
    }
  </section>
</BaseLayout>
